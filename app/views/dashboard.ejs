<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Campaign Dashboard</title>
    <link rel="stylesheet" href="/static/styles.css" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  </head>
  <body>
    <main class="container wide">
      <header class="header">
        <div>
          <h1>Campaign dashboard</h1>
          <p class="muted">Track acquisition channel conversion.</p>
        </div>
        <div class="header-actions">
          <a class="btn secondary" href="/signup?ref=fb-spring-1">Open signup</a>
        </div>
      </header>

      <section class="card">
        <form method="get" action="/dashboard" class="filters">
          <div class="field">
            <label for="start">Start date</label>
            <input id="start" name="start" type="date" value="<%= startDate %>" />
          </div>
          <div class="field">
            <label for="end">End date</label>
            <input id="end" name="end" type="date" value="<%= endDate %>" />
          </div>
          <div class="actions">
            <button type="submit" class="btn">Apply</button>
            <a class="link" href="/dashboard">Clear</a>
          </div>
        </form>
      </section>

      <section class="grid">
        <% campaigns.forEach((c) => { %>
          <article class="card">
            <div class="row">
              <div>
                <h2 class="h2"><%= c.name %></h2>
                <div class="pill"><%= c.source %></div>
              </div>
              <div class="kpis">
                <div class="kpi">
                  <div class="kpi-label">Total sign-ups</div>
                  <div class="kpi-value"><%= c.totalSignups %></div>
                </div>
                <div class="kpi">
                  <div class="kpi-label">Completed</div>
                  <div class="kpi-value"><%= c.completedSignups %></div>
                </div>
                <div class="kpi">
                  <div class="kpi-label">Conversion</div>
                  <div class="kpi-value"><%= (c.conversionRate * 100).toFixed(1) %>%</div>
                </div>
              </div>
            </div>

            <div class="chart-wrap">
              <canvas id="chart-<%= c.id %>" height="90"></canvas>
            </div>
          </article>
        <% }) %>
      </section>
    </main>
    <script>
      const seriesByCampaign = <%- JSON.stringify(seriesByCampaign) %>;
    </script>
    <script src="/js/chart.js"></script>
  </body>
</html>

